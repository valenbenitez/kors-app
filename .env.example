# =============================================================================
# Kors App — Environment variables
# Copy this file to `.env.local` and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# PDF generation (Puppeteer)
# -----------------------------------------------------------------------------
# Runtime mode:
#   local      — uses bundled Chromium from `puppeteer` (dev). Default for `pnpm dev`.
#   serverless — uses @sparticuz/chromium (Vercel / AWS Lambda). Default in production.
PDF_RUNTIME=local

# Optional: path to Chrome/Chromium when using puppeteer-core without bundled browser.
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Firebase client (web config — public; restrict via Firebase Auth / rules)
# Used by the browser SDK for Auth (email/password) and Firestore.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Firebase Admin (server-only — NUNCA NEXT_PUBLIC_)
# Used to verify ID tokens, create/verify session cookies, and Firestore Admin.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# FX rates (Google Sheet CSV export)
# -----------------------------------------------------------------------------
# Published CSV URL for live TC (USD, CLP, ARS, PEN, COP, MXN, BRL).
# Used by GET /api/rates and server-side PDF generation.
# RATES_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0

# -----------------------------------------------------------------------------
# Catalog sync (Sheet CSV → Firestore)
# -----------------------------------------------------------------------------
# Published CSV export URLs (same pattern as RATES_URL). When both are unset,
# POST /api/admin/sync-catalog seeds from bundled static data (local/dev).
# CATALOG_EXCURSIONS_SHEET_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0
# CATALOG_COPY_SHEET_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=1
#
# Auth for sync: Bearer token (preferred) or admin session. Falls back to CRON_SECRET.
# CATALOG_SYNC_SECRET=
# CRON_SECRET=
#
# Catalog read source for GET /api/catalog:
#   static    — always bundled JSON / pdf-copy
#   firestore — always Firestore (must sync first)
#   (unset)   — auto: Firestore when catalogMeta/sync exists, else static
# CATALOG_SOURCE=

# -----------------------------------------------------------------------------
# Emulator (tests / local)
# Requires Java (JRE 21+) for `pnpm test:firestore` / `pnpm emulators:firestore`.
# Leave unset for normal `pnpm test` / `pnpm build`.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# -----------------------------------------------------------------------------
# Vercel AI Gateway (vision extract — Prefill 2/4)
# Server-only. Required for POST /api/extract-quote-image at runtime.
# NOT required for `pnpm test` / `./init.sh` (mappers are unit-tested offline).
# Get a key from the Vercel dashboard → AI Gateway.
# Model used: anthropic/claude-sonnet-4.6 (vision + structured output).
# -----------------------------------------------------------------------------
# AI_GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# Admin access (optional — trip quote list/get)
# -----------------------------------------------------------------------------
# Comma-separated emails treated as admins (case-insensitive), in addition to
# Firebase custom claim `admin === true`. See docs/auth-quotes.md.
# ADMIN_EMAILS=boss@kors.com,ops@kors.com

# -----------------------------------------------------------------------------
# Google Drive (optional — PDF upload for POST /api/cotizaciones)
# -----------------------------------------------------------------------------
# When unset or credentials JSON is invalid → noop (pdf_drive_url: null).
# When both are set with a valid service-account JSON, PDFs upload under:
#   {GOOGLE_DRIVE_FOLDER_ID}/{YYYY-MM}/COT-XXXX.pdf
# Set GOOGLE_DRIVE_FOLDER_ID to the Drive folder id for
# "PDF-Cotizaciones-cliente-whatsapp" (share that folder with the SA email).
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON: raw JSON or base64-encoded JSON with
# client_email + private_key. Scope used: drive.file.
# Persist always succeeds first; Drive URL is patched after upload.
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
