# =============================================================================
# Kors App — Environment variables
# Copy this file to `.env.local` and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# PDF generation (Puppeteer)
# -----------------------------------------------------------------------------
# Runtime mode:
#   local      — uses bundled Chromium from `puppeteer` (dev). Default for `pnpm dev`.
#   serverless — uses @sparticuz/chromium (Vercel / AWS Lambda). Default in production.
PDF_RUNTIME=local

# Optional: path to Chrome/Chromium when using puppeteer-core without bundled browser.
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# Firebase client (web config — public; restrict via Firebase Auth / rules)
# Used by the browser SDK for Auth (email/password) and Firestore.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Firebase Admin (server-only — NUNCA NEXT_PUBLIC_)
# Used to verify ID tokens, create/verify session cookies, and Firestore Admin.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Emulator (tests / local)
# Requires Java (JRE 21+) for `pnpm test:firestore` / `pnpm emulators:firestore`.
# Leave unset for normal `pnpm test` / `pnpm build`.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
