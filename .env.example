# =============================================================================
# Kors App — Environment variables
# Copy this file to `.env.local` and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth (mock MVP)
# Fixed credentials used by POST /api/auth/login. Change for demos only.
# -----------------------------------------------------------------------------
AUTH_EMAIL=admin@kors.com
AUTH_PASSWORD=change-me

# Secret to sign session cookies (min 32 chars). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# -----------------------------------------------------------------------------
# PDF generation (Puppeteer)
# -----------------------------------------------------------------------------
# Runtime mode:
#   local      — uses bundled Chromium from `puppeteer` (dev). Default for `pnpm dev`.
#   serverless — uses @sparticuz/chromium (Vercel / AWS Lambda). Default in production.
PDF_RUNTIME=local

# Optional: path to Chrome/Chromium when using puppeteer-core without bundled browser.
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=
